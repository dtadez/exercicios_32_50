programa {
  funcao inicio() {
    inteiro n1, n2
    escreva("qual o primeiro número")
    leia(n1)
    escreva("qual o segundo número")
    leia(n2)
    se(n1>n2){
      escreva("o maior número é ",n1)
    }
    senao se(n1<n2){
      escreva("o maior número é ",n1)
    }
    senao {
      escreva("os números são iguais")
    }
  }
}
